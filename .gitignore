# config.nix is generated per-user and lives OUTSIDE this repo, at
# ~/.config/dotnix/config.nix (the flake reads it impurely via $DOTNIX_CONFIG).
# This ignore is a safety net: if someone writes config.nix in the repo root by
# habit, git will not track it and it can never be committed. See
# config.example.nix.
config.nix

# no-mistakes pipeline evidence should never be committed
.no-mistakes/

# nix build / rebuild output symlinks
result
result-*